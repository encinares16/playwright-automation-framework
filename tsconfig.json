{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@/*": ["./*"],
      "@utils/*": ["./src/utils/*"],
      "@pages/*": ["./src/pages/*"],
      "@flows/*": ["./src/flows/*"],
      "@types/*": ["./src/types/*"],
      "@fixtures/*": ["./src/fixtures/*"],
      "@test-data/*": ["./src/test-data/*"],
      "@assertions/*": ["./src/assertions/*"],
      "@components/*": ["./src/components/*"],
      "@interfaces/*": ["./src/interfaces/*"],
    }
  },
  "exclude": ["node_modules", "dist"]
}
